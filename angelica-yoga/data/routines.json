[
  {
    "id": "sun-salutation-a",
    "name": "Sun Salutation A",
    "sanskrit_name": "Surya Namaskar A",
    "type": "Sequence",
    "duration_minutes": 5,
    "level": "Beginner",
    "description": "The foundational Vinyasa warm-up. One round links breath to movement through nine postures, building heat and waking the body. Repeat 3 to 5 rounds.",
    "poses": [
      { "pose_id": "mountain", "hold_seconds": 5, "note": "Begin. Hands at heart center, eyes soft" },
      { "pose_id": "upward-salute", "hold_seconds": 3, "note": "Inhale — sweep arms wide and overhead" },
      { "pose_id": "standing-forward-fold", "hold_seconds": 3, "note": "Exhale — hinge from the hips, fold forward" },
      { "pose_id": "half-standing-forward-fold", "hold_seconds": 3, "note": "Inhale — halfway lift, lengthen the spine" },
      { "pose_id": "chaturanga", "hold_seconds": 4, "note": "Exhale — step or float back to Plank, lower halfway" },
      { "pose_id": "upward-dog", "hold_seconds": 3, "note": "Inhale — roll over the toes, lift the chest" },
      { "pose_id": "downward-dog", "hold_seconds": 25, "note": "Exhale — press back. Hold 5 full breaths" },
      { "pose_id": "half-standing-forward-fold", "hold_seconds": 3, "note": "Inhale — step or float forward, halfway lift" },
      { "pose_id": "standing-forward-fold", "hold_seconds": 3, "note": "Exhale — fold" },
      { "pose_id": "mountain", "hold_seconds": 5, "note": "Inhale rise; exhale hands to heart" }
    ]
  },
  {
