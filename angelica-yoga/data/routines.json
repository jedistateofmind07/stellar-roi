      { "pose_id": "supine-twist", "hold_seconds": 45, "note": "Left" },
      { "pose_id": "happy-baby", "hold_seconds": 45, "note": "Release the lower back" },
      { "pose_id": "reclined-bound-angle", "hold_seconds": 90, "note": "Soften completely" },
