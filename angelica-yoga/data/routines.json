      { "pose_id": "upward-dog", "hold_seconds": 3, "note": "Inhale" },
      { "pose_id": "downward-dog", "hold_seconds": 5, "note": "Exhale" },
      { "pose_id": "warrior-1", "hold_seconds": 5, "note": "Inhale — left foot forward, second side" },
      { "pose_id": "chaturanga", "hold_seconds": 4, "note": "Exhale — lower halfway" },
      { "pose_id": "upward-dog", "hold_seconds": 3, "note": "Inhale" },
      { "pose_id": "downward-dog", "hold_seconds": 25, "note": "Exhale — hold 5 breaths" },
      { "pose_id": "half-standing-forward-fold", "hold_seconds": 3, "note": "Inhale — halfway lift" },
      { "pose_id": "standing-forward-fold", "hold_seconds": 3, "note": "Exhale — fold" },
      { "pose_id": "chair", "hold_seconds": 5, "note": "Inhale — rise into Chair" },
      { "pose_id": "mountain", "hold_seconds": 5, "note": "Exhale — stand tall, hands at heart" }
    ]
  },
  {
