{
  "cleanUrls": true,
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/poses$", "dest": "/poses.html" },
    { "src": "^/pose$", "dest": "/pose.html" },
    { "src": "^/routines$", "dest": "/routines.html" },
    { "src": "^/routine$", "dest": "/routine.html" },
    { "src": "^/(.+\\.html)$", "dest": "/$1" },
    { "src": "^/(.+\\.css)$", "dest": "/$1" },
    { "src": "^/(.+\\.js)$", "dest": "/$1" },
    { "src": "^/(.+\\.json)$", "dest": "/$1" },
    { "src": "^/(.+\\.svg)$", "dest": "/$1" },
    { "src": "^/(.+\\.jpg)$", "dest": "/$1" },
    { "src": "^/(.+\\.png)$", "dest": "/$1" }
  ]
}
